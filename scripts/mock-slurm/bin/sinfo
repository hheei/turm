#!/usr/bin/env bash
# mock sinfo for turm tests
# Supports both --json (newer Slurm) and -o '%P %t' --noheader (older Slurm)
set -euo pipefail

# Check if --json flag is present
for arg in "$@"; do
    if [ "$arg" = "--json" ]; then
        cat <<'EOF'
{
  "nodes": [
    {"partition": "A", "state": "alloc"},
    {"partition": "A", "state": "alloc"},
    {"partition": "A", "state": "alloc"},
    {"partition": "A", "state": "alloc"},
    {"partition": "A", "state": "alloc"},
    {"partition": "A", "state": "alloc"},
    {"partition": "A", "state": "alloc"},
    {"partition": "A", "state": "alloc"},
    {"partition": "A", "state": "alloc"},
    {"partition": "B", "state": "alloc"},
    {"partition": "B", "state": "alloc"},
    {"partition": "B", "state": "alloc"},
    {"partition": "B", "state": "alloc"},
    {"partition": "B", "state": "alloc"},
    {"partition": "B", "state": "alloc"},
    {"partition": "B", "state": "alloc"},
    {"partition": "B", "state": "alloc"},
    {"partition": "B", "state": "alloc"},
    {"partition": "B", "state": "alloc"},
    {"partition": "B", "state": "mix"},
    {"partition": "B", "state": "mix"},
    {"partition": "B", "state": "mix"},
    {"partition": "B", "state": "mix"},
    {"partition": "B", "state": "mix"},
    {"partition": "B", "state": "idle"},
    {"partition": "B", "state": "idle"},
    {"partition": "B", "state": "idle"},
    {"partition": "B", "state": "idle"},
    {"partition": "B", "state": "idle"},
    {"partition": "B", "state": "idle"},
    {"partition": "B", "state": "idle"},
    {"partition": "B", "state": "down"},
    {"partition": "B", "state": "drain"},
    {"partition": "C", "state": "alloc"},
    {"partition": "C", "state": "alloc"},
    {"partition": "C", "state": "alloc"},
    {"partition": "C", "state": "alloc"},
    {"partition": "C", "state": "alloc"},
    {"partition": "C", "state": "alloc"},
    {"partition": "C", "state": "alloc"},
    {"partition": "C", "state": "alloc"},
    {"partition": "C", "state": "alloc"},
    {"partition": "C", "state": "alloc"},
    {"partition": "C", "state": "alloc"},
    {"partition": "C", "state": "alloc"},
    {"partition": "C", "state": "alloc"},
    {"partition": "C", "state": "alloc"},
    {"partition": "C", "state": "alloc"},
    {"partition": "C", "state": "alloc"},
    {"partition": "C", "state": "alloc"},
    {"partition": "C", "state": "alloc"},
    {"partition": "C", "state": "alloc"},
    {"partition": "C", "state": "alloc"},
    {"partition": "C", "state": "alloc"},
    {"partition": "C", "state": "idle"}
  ]
}
EOF
        exit 0
    fi
