# Plain format fallback (matches real Slurm 20.11+ output)
cat <<'EOF'
dcuZ100_fast idle
dcuZ100 idle
gpuA100_fast mix
gpuA100 mix
debug alloc
fast alloc
fast idle
normal_lmxu alloc
normal_lmxu idle
bigmem alloc
EOF
